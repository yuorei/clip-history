{
  "name": "@clip-history/desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --strictPort",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && npm run start:electron",
    "start": "electron .",
    "start:electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc && tsc -p tsconfig.electron.json && vite build",
    "dist": "npm run build && electron-builder --mac --dir",
    "preview": "vite preview"
  },
  "build": {
    "appId": "local.clip-history",
    "productName": "Clip History",
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "41.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
